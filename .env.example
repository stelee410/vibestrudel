# 服务端 LLM (云端 LLM 路径必需)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# 月度上限 (USD), 超过后云端 LLM 路径返回 429 budget_exceeded
MONTHLY_CAP_USD=30

# Session TTL (秒)
SESSION_TTL_SECONDS=300

# 限流 (秒)
GLOBAL_RATE_SECONDS=15
PER_IP_RATE_SECONDS=60
SELF_RATE_SECONDS=5

# LLM 校验失败后最多重试次数
LLM_MAX_RETRY=1

# CORS 允许的来源, 逗号分隔, 默认 production 锁定到 https://live.linkyun.co
CORS_ORIGIN=https://live.linkyun.co
