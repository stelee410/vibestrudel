# =====================================================
# VibeStrudel Live · Caddy 反向代理
#
# 路由规则:
#   /                       → landing.html (酷炫首页)
#   /app                    → index.html (单机模式)
#   /s/:id                  → index.html (live 客户端 SPA, 浏览器导航)
#
#   POST /sessions          → app:8080 (创建 session)
#   GET  /s/:id/code        → app:8080 (轮询当前代码)
#   PUT  /s/:id/code        → app:8080 (推代码, 自带 LLM 路径)
#   PUT  /s/:id/text        → app:8080 (推文字, 云端 LLM 路径)
#   GET  /healthz, /stats   → app:8080
#
#   /themes/*, /vendor/*    → 静态文件 (长缓存)
# =====================================================

(common) {
    root * /srv/public

    # === API 端点 ===
    handle /sessions {
        reverse_proxy app:8080
    }
    handle /healthz {
        reverse_proxy app:8080
    }
    handle /stats {
        reverse_proxy app:8080
    }

    # /s/:id/code, /s/:id/text 的所有方法 → 转发
    @session_action path_regexp ^/s/[a-zA-Z0-9_-]+/(code|text)$
    handle @session_action {
        reverse_proxy app:8080
    }

    # === 应用页面 ===
    handle / {
        rewrite * /landing.html
        file_server
    }
    handle /app {
        rewrite * /index.html
        file_server
    }
    # /s/:id (无后缀) → 永远返回 SPA index.html (浏览器分享 URL)
    @session_view path_regexp ^/s/[a-zA-Z0-9_-]+$
    handle @session_view {
        rewrite * /index.html
        file_server
    }

    # === 静态资源 ===
    handle {
        file_server
        @assets path /vendor/* /themes/*
        header @assets Cache-Control "public, max-age=31536000, immutable"
    }

    encode gzip zstd
}

# 生产域名
live.linkyun.co {
    import common
    log
}

# 本地测试(无域名)
:80 {
    import common
}
